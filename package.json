{
  "name": "borntoco.de",
  "version": "1.0.0",
  "description": "my personal website",
  "main": "index.js",
  "scripts": {
    "start": "NODE_ENV=test node static.js",
    "watch-test": "NODE_ENV=test watch 'npm test && npm run lint' --wait=3 ./src",
    "watch": "NODE_ENV=test watch 'npm run build' --wait=3 ./src",
    "test": "NODE_ENV=test nyc ./node_modules/.bin/_mocha",
    "build": "NODE_ENV=production webpack",
    "lint": "tslint --project ./tsconfig.json",
    "lint:fix": "tslint --project ./tsconfig.json --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/op1ekun/borntoco.de.git"
  },
  "keywords": [
    "personal",
    "cv",
    "portfolio",
    "website"
  ],
  "author": "op1ekun@borntoco.de",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/op1ekun/borntoco.de/issues"
  },
  "homepage": "https://github.com/op1ekun/borntoco.de#readme",
  "devDependencies": {
    "@types/chai": "^4.1.7",
    "@types/enzyme": "^2.8.12",
    "@types/mocha": "^2.2.48",
    "@types/react": "^15.6.24",
    "@types/react-dom": "^15.5.10",
    "@types/react-redux": "^7.0.8",
    "@types/react-router-dom": "^4.3.2",
    "@types/redux": "^3.6.0",
    "chai": "^4.2.0",
    "enzyme": "^2.9.1",
    "express": "^4.16.4",
    "jest": "^24.7.1",
    "jsdom": "^11.12.0",
    "mocha": "^4.1.0",
    "nyc": "^11.9.0",
    "react-test-renderer": "^15.6.2",
    "ts-loader": "^3.5.0",
    "ts-node": "^3.3.0",
    "tslint": "^5.16.0",
    "tslint-react": "^3.6.0",
    "typescript": "^2.9.2",
    "watch": "^1.0.2",
    "webpack": "^3.12.0"
  },
  "dependencies": {
    "react": "^16.8.6",
    "react-dom": "^16.8.6",
    "react-redux": "^7.0.2",
    "react-router-dom": "^4.3.1",
    "redux": "^4.0.1"
  },
  "nyc": {
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx"
    ],
    "exclude": [
      "src/**/*.test.ts",
      "src/**/*.test.tsx",
      "node_modules/",
      "dist/"
    ],
    "extension": [
      ".ts",
      ".tsx"
    ],
    "require": [
      "ts-node/register"
    ],
    "reporter": [
      "text-summary",
      "html"
    ],
    "sourceMap": true,
    "instrument": true
  }
}
